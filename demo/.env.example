# Passkey Kit demo — PUBLIC configuration only.
#
# Copy to `.env.local` and fill in. There are NO secrets here: the relayer API
# key and the Mercury / Stellar Indexer JWTs live only in the server-side proxy
# worker (see repo `relayer-proxy/`). The demo talks to that worker over the
# *Proxy URLs below and never sees a token. Never add a VITE_-prefixed secret.

# --- Network -----------------------------------------------------------------
VITE_rpcUrl="https://soroban-testnet.stellar.org"
VITE_networkPassphrase="Test SDF Network ; September 2015"

# Smart-wallet WASM hash — pinned from docs/deployments-testnet-2026-07-11.md
# (canonical source). Re-pinned after the contract audit gate + bindings regen.
VITE_walletWasmHash="9e7fad441d6560b31eafbf3b627dbc196cf19df4dcdb91e0aededaf6590d6fbe"

# --- Tokens (SAC / SEP-41) ---------------------------------------------------
# Native XLM SAC on testnet.
VITE_nativeContractId="CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC"
# Optional extra tokens for the non-native SAC demo: comma-separated label:C…
# VITE_extraTokenIds="USDC:C..."

# --- Policy signer (optional) ------------------------------------------------
# Deployed instance of the v1 sample-policy contract. Leave blank to disable the
# policy-signer controls. Deploy from the sample-policy WASM in the manifest.
# VITE_samplePolicyId="C..."

# --- Server-side proxies (no secrets in the browser) -------------------------
# Relayer-proxy worker (submission). Unset => submission disabled in the UI.
# VITE_relayerProxyUrl="https://passkey-kit-relayer-proxy.<you>.workers.dev"
# Indexer-proxy (signer discovery, Mercury + Stellar Indexer). Unset => discovery
# shows "pending backend".
# VITE_indexerProxyUrl="https://passkey-kit-relayer-proxy.<you>.workers.dev"
